# =========================================================================
# .env.example  -  copy to `.env` and fill in. `.env` is gitignored, so keep
# all credentials and API keys here, NOT in config.sh.
#
#   cp .env.example .env && $EDITOR .env
#
# config.sh sources this first, so anything set here overrides the defaults.
# Lines are shell assignments; quote values containing spaces or specials.
# =========================================================================

# --- Active Directory credentials (internal mode, OPTIONAL) ---------------
# Read-only creds enable authenticated LDAP/BloodHound/roasting in phases 03/06.
# Leave blank for fully unauthenticated recon. Never sprayed or brute-forced.
# DOMAIN=CORP.LOCAL
# DC_IP=10.10.10.10
# USERNAME=jdoe
# PASSWORD='Summer2025!'
# NTHASH=                       # NTLM hash for pass-the-hash (instead of PASSWORD)

# --- AI augmentation (OPTIONAL) -------------------------------------------
# Only the SELECTED provider's key is needed (ollama needs none).
# AI_PROVIDER=anthropic         # none | anthropic | openai | gemini | ollama
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# --- External passive-source API keys (external mode, OPTIONAL) -----------
# SHODAN_API_KEY=
# CENSYS_API_ID=
# CENSYS_API_SECRET=
# SECURITYTRAILS_API_KEY=
